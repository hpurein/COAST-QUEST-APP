---
import '../styles/global.css';
import Header from '../components/header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coast Quest — Coastal knowledge made easy.</title>
    
    <meta property="og:title" content="Coast Quest — Coastal knowledge made easy." />
    <meta property="og:description" content="Coast Quest is a free public service that provides all the information beachgoers need about their local coastal environments." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://www.thecoastquest.com/assets/og-image-v2.jpg" />
    <meta property="og:url" content="https://www.thecoastquest.com/" />
  
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Coast Quest — Coastal knowledge made easy." />
    <meta name="twitter:description" content="Coast Quest is a free public service that provides all the information beachgoers need about their local coastal environments." />
    <meta name="twitter:image" content="https://www.thecoastquest.com/assets/og-image-v2.jpg" />
  
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inknut+Antiqua:wght@400;600&family=Rethink+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
<body class="overflow-x-hidden bg-coast-beige">
  <Header />
  
 <!-- HERO SECTION -->
  <!-- 1. Swapped 'items-center' for 'items-start' so it anchors to the top -->
<section id="hero" class="relative w-full min-h-[85vh] md:min-h-screen bg-coast-beige overflow-hidden flex items-center pt-32 pb-32 md:py-0">
    
  <img 
  id="hero-trail"
  src="/assets/trail-new.png" 
  alt="" 
  class="trail-reveal absolute bottom-[0%] left-[-40%] w-[180%] max-w-none md:bottom-[0%] md:left-[-5%] md:w-[110%] h-auto pointer-events-none z-0 opacity-90" 
/>

    <div class="max-w-7xl mx-auto px-6 w-full grid md:grid-cols-2 gap-12 items-center relative z-10">
      
      <div class="max-w-lg relative z-10 md:-translate-y-25">
        <h1 class="text-hero text-coast-brown mb-6">
          Coastal knowledge <br/> made easy
        </h1>
        <p class="text-body-large text-coast-brown mb-12 leading-relaxed max-w-[420px]">
          <strong> Coast Quest </strong> is a free public service that provides all the information beachgoers need about their local coastal environments.
        </p>

        <p class="text-body-large text-coast-brown mb-2 leading-relaxed max-w-[420px]">
          Scroll down to learn how we work ↓
        </p>
      </div>
      
      <div class="flex justify-center items-center relative z-10 mt-16 md:mt-0 md:-translate-y-30">
        <img src="/assets/loc-icon.png" alt="Location Pin" class="float-anim object-contain w-full max-w-[160px]"/>
      </div>

    </div>
  </section>

<!-- MOVIE -->

  <section id="the-story" class="py-24 px-6 max-w-7xl mx-auto">
    
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h2 class="text-section-header text-coast-brown m-0 mb-8 leading-none">
          See the coast <br class="hidden md:block" /> in action
        </h2>
        <p class="text-body-large text-coast-brown max-w-md md:text-left opacity-90">
          Follow Moll as she explores the smart coast, meets the mascots, and discovers how Coast Quest works in the wild.
        </p>
      </div>
    </div>

    <div class="relative w-full aspect-video border-2 border-coast-brown bg-coast-brown shadow-[8px_8px_0_#432D26] transition-transform duration-300 hover:-translate-y-2 hover:shadow-[12px_12px_0_#432D26]">
      
      <iframe 
        class="w-full h-full absolute inset-0"
        src="https://www.youtube.com/embed/BZck3Q3hnus?rel=0&modestbranding=1" 
        title="Coast Quest: This is Moll" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        referrerpolicy="strict-origin-when-cross-origin" 
        allowfullscreen>
      </iframe>
      
    </div>
    
  </section>

  <!-- WHY WE EXIST SECTION -->


  <section id="why-we-exist" class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="text-section-header text-coast-brown mb-6">
          There is a gap between data and families
        </h2>
        <p class="text-body-large text-coast-brown mb-4">
          Water quality reports are currently way too complicated. The data is hidden in complex government websites and written in scientific jargon that most people can't understand.
        </p>
        <p class="text-body-large text-coast-brown mb-8">
          Coast Quest translates that data into one simple message: <strong> is it a good day to swim or not? </strong> 
        </p>
      </div>
      
      <div class="flex flex-col gap-4 w-full max-w-md mx-auto md:ml-auto">
        <div class="text-mono-label text-sm opacity-60">RAW TABLE DATA:</div>

        <!-- RAW TABLE DATA -->
       
        <div class="bg-coast-yellow p-6 border-2 border-coast-brown font-mono text-sm text-coast-brown leading-relaxed tracking-tight">
          Enterococci: 142 CFU/100ml<br/>
          Turbidity: 18.4 NTU<br/>
          HAB Alert: Aphanizomenon detected<br/>
          pH: 7.9 | Temp: 14.2°C<br/><br/>
          Exceeds bathing water directive 2006/7/EC
        </div>
        

      <!-- OUR TRANSLATION-->

        <div class="text-mono-label text-sm opacity-60 mt-4">OUR TRANSLATION:</div>

        <div class="flex justify-center items-center border-2 border-coast-brown">
          <img src="/assets/our-translation-2.png" alt="E-ink Display" class="w-full object-contain" />
        </div>
  
      </div>
    </div>
  </section>


  
  <!-- THE COAST QUEST EXPERIENCE SECTION -->

  <section id="the-coast-quest-experience" class="py-24 px-6 max-w-7xl mx-auto">
    <div class="mb-12 max-w-3xl">
      <h2 class="text-section-header text-coast-brown mb-6">
        The Coast Quest Experience
      </h2>
      <p class="text-body-large text-coast-brown">
        Coast Quest isn't just an adventure. It is a multiple touchpoint service, designed for both target groups; children and guardians. It is a seamless loop of physical installations, eco-friendly technology, and hands-on rewards designed specifically for coastal environments.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <div class="border-2 border-coast-brown bg-coast-beige flex flex-col transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
        <div class="aspect-[4/3] bg-coast-blue">
          <img src="/assets/clear-data-photo-2.png" alt="Clear data screens" class="w-full h-full object-cover" />
        </div>
        <div class="p-5 flex-1">
          <h3 class="font-heading text-xl text-coast-brown mb-3 tracking-tight leading-tight">Clear data on eco-friendly screens.</h3>
          <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
            We display real-time environmental updates in simple, family-friendly language so parents don't have to decode scientific jargon. Delivered on zero-glare E-ink screens, the information stays readable in bright sunlight without causing light pollution that disrupts local marine wildlife.
          </p>
        </div>
      </div>
      
      <div class="border-2 border-coast-brown bg-coast-beige flex flex-col transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
        <div class="aspect-[4/3] bg-coast-green">
          <img src="/assets/hands-on-stations-2.jpg" alt="Hands-on learning" class="w-full h-full object-cover" />
        </div>
        <div class="p-5 flex-1">
          <h3 class="font-heading text-xl text-coast-brown mb-3 tracking-tight leading-tight">Hands-on learning stations.</h3>
          <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
            Kids learn best by doing. Our interactive installations provide education about natural phenomena and encourages experimentation, which strengthens cognitive development and builds a deeper, tactile connection to the natural world.
          </p>
        </div>
      </div>
      
      <div class="border-2 border-coast-brown bg-coast-beige flex flex-col transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
        <div class="aspect-[4/3] bg-coast-yellow">
          <img src="/assets/journal-pic.png" alt="Explorer's Journal" class="w-full h-full object-cover" />
        </div>
        <div class="p-5 flex-1">
          <h3 class="font-heading text-xl text-coast-brown mb-3 tracking-tight leading-tight">The Explorer’s Journal</h3>
          <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
            A physical guidebook filled with drawing prompts and checklists that turns a normal beach walk into a treasure hunt. By rewarding curiosity, the journal encourages children to actively engage with their surroundings.
          </p>
        </div>
      </div>
      
      <div class="border-2 border-coast-brown bg-coast-beige flex flex-col transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
        <div class="aspect-[4/3] bg-coast-magenta">
          <img src="/assets/device-mockups.png" alt="Water Vibe Platform" class="w-full h-full object-cover" />
        </div>
        <div class="p-5 flex-1">
          <h3 class="font-heading text-xl text-coast-brown mb-3 tracking-tight leading-tight">Water Vibe Platform</h3>
          <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
            A free live dashboard tool for parents. Check local beach germ levels, algae status, and water clarity right from your phone before you even pack the beach bag.
          </p>
        </div>
      </div> 

    </div>

<!-- VISITING THE BEACH-->

  </section> <section id="water-vibe-dashboard" class="w-full py-24 bg-coast-yellow " style="clip-path: polygon(0 8%, 100% 0, 100% 100%, 0 100%);"> 
    <div class="max-w-7xl py-24 mx-auto px-6"> 
      
      <div class="grid md:grid-cols-2 gap-12 items-start">
        
        <div>
          <h2 class="text-section-header text-coast-brown mb-4">
            Visiting the Beach?
          </h2>
          <p class="text-body-large text-coast-brown max-w-xl mb-8">
            Live dashboard tool free to use for everyone. Get the latest information about beach water germ levels, algae status and acidity before you leave the house.
          </p>
          <a href="/water-vibe" class="btn btn-primary inline-block">
            Go to Water Vibe Platform
          </a>
        </div>

        <div class="flex justify-center items-center">
          <div class="w-full md:w-[80%] grid grid-cols-2 border-t-2 border-l-2 border-coast-brown">
            
            <div class="border-b-2 border-r-2 border-coast-brown aspect-square bg-coast-beige p-4 md:p-6 flex flex-col relative overflow-hidden">
              <div class="flex justify-between items-start z-10">
                <span class="font-sans text-sm md:text-lg text-coast-brown tracking-tight leading-tight w-1/2">Health:</span>
                <span class="bg-coast-green text-coast-beige px-3 md:px-4 py-1 rounded-full text-xs md:text-sm font-sans tracking-wide">great</span>
              </div>
              <div class="flex-1 flex items-center justify-center mt-4">
                <img src="/assets/platform/icons/icon-eyes.png" alt="Eyes" class="w-2/3 h-auto object-contain" />
              </div>
            </div>

            <div class="border-b-2 border-r-2 border-coast-brown aspect-square bg-coast-green p-4 md:p-6 flex flex-col relative overflow-hidden">
              <div class="flex justify-between items-start z-10">
                <span class="font-sans text-sm md:text-lg text-white tracking-tight leading-tight w-1/2">Bacteria:</span>
                <span class="bg-white text-coast-brown px-3 md:px-4 py-1 rounded-full text-xs md:text-sm font-sans tracking-wide">low</span>
              </div>
              <div class="flex-1 flex items-center justify-center mt-4">
                <img src="/assets/platform/icons/icon-magnifying.png" alt="Magnifying Glass" class="w-2/3 h-auto object-contain" />
              </div>
            </div>

            <div class="border-b-2 border-r-2 border-coast-brown aspect-square bg-coast-green p-4 md:p-6 flex flex-col relative overflow-hidden">
              <div class="flex justify-between items-start z-10">
                <span class="font-sans text-sm md:text-lg text-white tracking-tight leading-tight w-1/2">Algae:</span>
                <span class="bg-white text-coast-brown px-3 md:px-4 py-1 rounded-full text-xs md:text-sm font-sans tracking-wide">safe</span>
              </div>
              <div class="flex-1 flex items-center justify-center p-4 mt-2">
                <img src="/assets/platform/icons/icon-seaweed.png" alt="Seaweed" class="max-w-[55%] max-h-full object-contain" />
              </div>
            </div>

            <div class="border-b-2 border-r-2 border-coast-brown aspect-square bg-coast-beige p-4 md:p-6 flex flex-col relative overflow-hidden">
              <div class="flex justify-between items-start z-10">
                <span class="font-sans text-sm md:text-lg text-coast-brown tracking-tight leading-tight w-1/2">Pollution:</span>
                <span class="bg-coast-green text-coast-beige px-3 md:px-4 py-1 rounded-full text-xs md:text-sm font-sans tracking-wide">clean</span>
              </div>
              <div class="flex-1 flex items-center justify-center mt-4 z-10">
                <img src="/assets/platform/icons/icon-fish.png" alt="fish" class="w-3/5 h-auto object-contain scale-125" />
              </div>
            </div>

            <div class="border-b-2 border-r-2 border-coast-brown aspect-square bg-coast-beige p-4 md:p-6 flex flex-col relative overflow-hidden">
              <div class="flex justify-between items-start z-10">
                <span class="font-sans text-sm md:text-lg text-coast-brown tracking-tight leading-tight w-1/2">Clarity:</span>
                <span class="bg-coast-green text-coast-beige px-3 md:px-4 py-1 rounded-full text-xs md:text-sm font-sans tracking-wide">clear</span>
              </div>
              <div class="flex-1 flex items-center justify-center mt-4 z-10">
                <img src="/assets/platform/icons/icon-sparkles.png" alt="Sparkles" class="w-3/5 h-auto object-contain scale-110" />
              </div>
            </div>

            <div class="border-b-2 border-r-2 border-coast-brown aspect-square bg-coast-green p-4 md:p-6 flex flex-col relative overflow-hidden">
              <div class="flex justify-between items-start z-10">
                <span class="font-sans text-sm md:text-lg text-white tracking-tight leading-tight w-1/2">Acidity:</span>
                <span class="bg-white text-coast-brown px-3 md:px-4 py-1 rounded-full text-xs md:text-sm font-sans tracking-wide">balanced</span>
              </div>
              <div class="flex-1 flex items-center justify-center mt-4">
                <img src="/assets/platform/icons/icon-ph.png" alt="pH Scale" class="w-2/3 h-auto object-contain" />
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>


  <section id="crew" class="w-full py-24 bg-coast-beige">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-12">
        <h2 class="text-section-header text-coast-brown mb-6">
          Meet Our Mascots:
        </h2>
        <p class="text-body-large text-coast-brown mt-4 max-w-xl">
          Every country has its own Coast Quest mascot, who acts as your guide, sharing fun facts and helping you explore safely.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="border-2 border-coast-brown bg-coast-beige transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
          <div class="h-48 flex items-center justify-center bg-coast-beige">
            <img src="/assets/Seal.png" alt="Seal" class="w-full h-full object-contain p-6" />
         </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <span class="font-heading text-xl text-coast-brown tracking-tight">Bob</span>
              <span class="text-mono-label text-[10px] border-2 border-coast-brown px-2 py-1">Finland</span>
            </div>
            <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
              Playful and curious, Bob knows every rock and crevice along the Baltic shore. Ask her about the best spots to find sea glass!
            </p>
          </div>
        </div>

        <div class="border-2 border-coast-brown bg-coast-beige transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
          <div class="h-48 flex items-center justify-center bg-coast-beige">
            <img src="/assets/Puffin.png" alt="Puffin" class="w-full h-full object-contain p-6" />
         </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <span class="font-heading text-xl text-coast-brown tracking-tight">Puff</span>
              <span class="text-mono-label text-[10px] border-2 border-coast-brown px-2 py-1">Ireland</span>
            </div>
            <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
              Bold and a little dramatic. Loves cliff-top viewpoints and can spot a fish gang from a mile away. He'll always tell you the weather forecast!
            </p>
          </div>
        </div>

        <div class="border-2 border-coast-brown bg-coast-beige transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
          <div class="h-48 flex items-center justify-center bg-coast-beige">
            <img src="/assets/Otter.png" alt="Otter" class="w-full h-full object-contain p-6" />
         </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <span class="font-heading text-xl text-coast-brown tracking-tight">Ūdris</span>
              <span class="text-mono-label text-[10px] border-2 border-coast-brown px-2 py-1">Latvia</span>
            </div>
            <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
              Ūdris is a master of rivers. He'll show you how to read tidal marks and identify which shells were left by the tide overnight!
            </p>
          </div>
        </div>

        <div class="border-2 border-coast-brown bg-coast-beige transition-transform hover:-translate-y-1 hover:shadow-[4px_4px_0_#432D26]">
          <div class="h-48 flex items-center justify-center bg-coast-beige">
            <img src="/assets/penguin.png" alt="Penguin" class="w-full h-full object-contain p-6" />
         </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <span class="font-heading text-xl text-coast-brown tracking-tight">Pisco</span>
              <span class="text-mono-label text-[10px] border-2 border-coast-brown px-2 py-1">Chile</span>
            </div>
            <p class="font-sans text-sm text-coast-brown leading-normal tracking-tight">
              Cool, calm and stylish, Pisco navigates cold currents like a pro. He knows every forest secret along the Pacific coast.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  
  <section id="journal" class="w-full py-24 bg-coast-yellow" style="clip-path: polygon(0 8%, 100% 0, 100% 100%, 0 100%);">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center py-16">
      <div>
        <h2 class="text-section-header text-coast-brown mb-6">
          The Explorer's Journal for Youngsters
        </h2>
        <p class="text-body-large text-coast-brown mb-4">
          A physical journal that children take on their coastal adventure. Each chapter introduces a new topic—from tidal creatures to water quality—through drawing prompts, checklists, and open-ended discovery. The journal offers a lasting, meaningful relationship with nature and empowers youth to protect our ecosystems, which directly aligns with the key EU social, environmental, and governance goals.         
        </p>
        <p class="text-body-large text-coast-brown mb-8">
          Complete the journal and send it in to earn an official <strong>Young Explorer Certificate</strong>—something worth framing!
        </p>
        <div class="space-y-3 mb-8">
          <div class="flex items-start gap-3">
            <span class="font-sans text-lg tracking-tight text-coast-brown">● Drawing &amp; observation prompts for the shoreline</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="font-sans text-lg tracking-tight text-coast-brown">● Fun facts delivered by the local mascot</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="font-sans text-lg tracking-tight text-coast-brown">● Creature identification checklists &amp; habitat maps</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="font-sans text-lg tracking-tight text-coast-brown">● Self learning and development</span>
          </div>
        </div>
        <a href="/assets/Journal-print.pdf" download="journal-print.pdf" class="btn btn-primary">
          Download printable PDF here
        </a>
      </div>
      <div class="flex items-center justify-center">
        <div class="w-72 h-96 border-2 border-coast-brown bg-coast-yellow shadow-[8px_8px_0_#432D26] flex items-center justify-center -rotate-2">
            <img src="/assets/journal.png" alt="Explorer Journal" class="w-full h-full object-cover" />        
        </div>
      </div>
    </div>
  </section>

<!-- WAITLIST -->

  <section  id="waitlist" class="w-full py-8 bg-coast-beige border-t-2 border-coast-brown">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl text-coast-brown tracking-tight leading-tight mb-6">
        Coast Quest is coming to a shore near you.
      </h2>
      <p class="text-mono-label text-coast-brown mb-8 text-xs opacity-60 text-center">
        We're currently developing in Helsinki. Sign up to be notified when we launch.
      </p>
      </div>
    </div>
  </section>

<!-- FOOTER -->


  <footer class="w-full py-8 border-t-2 border-coast-brown bg-coast-beige">
    <div class="max-w-7xl mx-auto px-6 flex flex-col items-center justify-center">
      <p class="text-mono-label text-xs opacity-60 text-center">
       BUILT WITH LOVE IN AALTO UNIVERSITY
      </p>
    </div>
  </footer>

  <script>
    // 1. The Trail Animation Script
    document.addEventListener('DOMContentLoaded', () => {
      
      const trail = document.getElementById('hero-trail');
      
      if (trail) {
        setTimeout(() => {
          const trailWidth = trail.getBoundingClientRect().width;
          const pixelsPerSecond = 360;
          const totalSeconds = trailWidth / pixelsPerSecond;
          trail.style.animationDuration = `${totalSeconds}s`;
        }, 100); 
      }

    }); // <-- THIS WAS MISSING! It closes the DOMContentLoaded listener.

    // 2. The Waitlist Form UI Script (Kept outside so the button can click it)
    function handleWaitlist() {
      const email = document.getElementById('email-input').value;
      if (!email || !email.includes('@')) {
        document.getElementById('email-input').style.borderColor = '#C84C71';
        return;
      }
      document.getElementById('waitlist-form').classList.add('hidden');
      document.getElementById('waitlist-success').classList.remove('hidden');
    }
  </script>
  </body>
</html>